# ─────────────────────────────────────────────
#  Ascendra — Personal Testing Configuration
#  Copy this file to .env and fill in your values
# ─────────────────────────────────────────────

# ── GROQ (FREE — no billing needed) ──────────
# Get your key at: https://console.groq.com/keys
GROQ_API_KEY=gsk_your_groq_key_here

# ── LINKEDIN ──────────────────────────────────
# Your personal LinkedIn login credentials
# These stay on your machine — never shared
LINKEDIN_EMAIL=your@email.com
LINKEDIN_PASSWORD=yourpassword

# ── GMAIL (choose ONE option below) ──────────

# Option A — Gmail OAuth2 (recommended, more reliable)
# Download from: console.cloud.google.com → Gmail API → OAuth Desktop App
GMAIL_CREDENTIALS_PATH=./gmail_credentials.json

# Option B — Gmail App Password (simpler setup)
# Go to: myaccount.google.com → Security → App Passwords → Generate
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=xxxx-xxxx-xxxx-xxxx

# ── OPTIONAL (leave blank if not needed yet) ──
# YouTube Data API v3 — for validating course links
# Get free key at: console.cloud.google.com
YOUTUBE_API_KEY=

# Hunter.io — for finding HR email addresses (25 free/month)
# Get free key at: hunter.io
HUNTER_API_KEY=

# ── RATE LIMITS (safe defaults — do not increase) ──
LINKEDIN_MAX_CONNECTIONS_PER_DAY=20
LINKEDIN_MAX_MESSAGES_PER_DAY=20
LINKEDIN_DELAY_SECONDS=4.0
