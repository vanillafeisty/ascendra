# ── Ascendra Web — Environment Variables ──────────────────────────────────────
# Copy this file to .env.local for local dev
# Add these as Environment Variables in Vercel dashboard for production

# URL of your Render backend
# Local dev:   http://localhost:8000
# Production:  https://ascendra-backend.onrender.com  (your Render URL)
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000
